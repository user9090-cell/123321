# 会理市AI数字人导游 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ========== 基础配置 ==========
# 应用名称和版本
APP_NAME="会理市AI数字人导游系统"
VERSION="1.0.0"

# 调试模式 (True/False)
DEBUG=False

# 服务器配置
HOST="0.0.0.0"
PORT=5000

# ========== 小米大模型配置 ==========
# 小米API密钥 (必填，从小米开放平台获取)
XIAOMI_API_KEY="your_xiaomi_api_key_here"

# 模型选择 (mimo-v2-flash / mimo-v2-pro)
XIAOMI_MODEL="mimo-v2-flash"

# API基础URL (通常不需要修改)
XIAOMI_BASE_URL="https://api.xiaomimimo.com/v1"

# ========== 模型参数配置 ==========
# 最大生成token数
MAX_TOKENS=120

# 温度参数 (0-1，值越小输出越确定)
TEMPERATURE=0.3

# Top-p采样参数
TOP_P=0.9

# ========== 嵌入模型配置 ==========
# 嵌入模型名称 (中文优化模型)
EMBEDDING_MODEL="BAAI/bge-small-zh-v1.5"

# 嵌入模型缓存路径
EMBEDDING_CACHE_PATH="./models/embeddings"

# ========== 向量数据库配置 ==========
# ChromaDB存储路径
CHROMA_DB_PATH="./backend/chroma_db"

# 集合名称
COLLECTION_NAME="huili_knowledge_base"

# ========== 缓存配置 ==========
# Redis连接URL (留空则使用fakeredis)
REDIS_URL=""

# 缓存过期时间 (秒)
CACHE_TTL=3600

# 是否使用fakeredis (True/False)
USE_FAKE_REDIS=True

# ========== 音频处理配置 ==========
# Whisper模型大小 (tiny/base/small/medium/large)
WHISPER_MODEL="tiny"

# 最大音频文件大小 (字节)
MAX_AUDIO_SIZE=10485760

# ========== 安全配置 ==========
# Flask密钥 (用于会话加密)
SECRET_KEY="your-secret-key-change-me"

# 管理员密码 (用于后台管理)
ADMIN_PASSWORD="your_admin_password_here"

# ========== 文件路径配置 ==========
# 日志目录
LOGS_DIR="./backend/logs"

# 知识库目录
KNOWLEDGE_BASE_DIR="./knowledge_base"

# ========== 性能配置 ==========
# 最大并发请求数
MAX_CONCURRENT_REQUESTS=10

# 请求超时时间 (秒)
REQUEST_TIMEOUT=30

# ========== 地理位置配置 ==========
# 默认纬度 (会理市)
DEFAULT_LATITUDE=26.6584

# 默认经度 (会理市)
DEFAULT_LONGITUDE=102.2437

# 附近搜索半径 (公里)
NEARBY_RADIUS_KM=10.0

# ========== RAG检索配置 ==========
# 返回结果数量
TOP_K_RESULTS=3

# 相似度阈值 (0-1)
SIMILARITY_THRESHOLD=0.7

# 向量相似度权重
VECTOR_WEIGHT=0.8

# BM25关键词权重
BM25_WEIGHT=0.2

# ========== 部署配置 ==========
# Gunicorn工作进程数 (生产环境建议设置为CPU核心数*2+1)
GUNICORN_WORKERS=4

# Gunicorn工作进程类型 (sync/gevent/eventlet)
GUNICORN_WORKER_CLASS="sync"

# Gunicorn绑定地址
GUNICORN_BIND="0.0.0.0:5000"

# ========== 监控配置 ==========
# 是否启用性能监控 (True/False)
ENABLE_MONITORING=True

# 监控端口 (Prometheus metrics)
MONITOR_PORT=9090

# ========== 日志配置 ==========
# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL="INFO"

# 日志文件路径
LOG_FILE="./backend/logs/app.log"

# 是否启用JSON日志格式
JSON_LOGS=False

# ========== 邮件通知配置 (可选) ==========
# SMTP服务器
SMTP_SERVER=""

# SMTP端口
SMTP_PORT=587

# SMTP用户名
SMTP_USERNAME=""

# SMTP密码
SMTP_PASSWORD=""

# 发件人邮箱
EMAIL_FROM=""

# 管理员邮箱 (接收系统通知)
ADMIN_EMAIL=""

# ========== 第三方服务配置 (可选) ==========
# 高德地图API密钥 (用于地图显示)
AMAP_API_KEY=""

# 微信小程序AppID
WECHAT_APPID=""

# 微信小程序Secret
WECHAT_SECRET=""

# ========== 开发配置 ==========
# 是否启用热重载 (开发环境)
ENABLE_RELOAD=True

# 是否启用CORS (开发环境)
ENABLE_CORS=True

# CORS允许的源
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# ========== 测试配置 ==========
# 测试模式 (True/False)
TEST_MODE=False

# 测试数据库路径
TEST_DB_PATH="./test_chroma_db"

# 测试API密钥
TEST_API_KEY="test_key_123456"

# ========== 备份配置 ==========
# 自动备份间隔 (小时，0表示禁用)
BACKUP_INTERVAL_HOURS=24

# 备份保留天数
BACKUP_RETENTION_DAYS=7

# 备份目录
BACKUP_DIR="./backups"

# ========== 说明 ==========
# 1. 将本文件复制为 .env
# 2. 填写必要的配置值（特别是XIAOMI_API_KEY）
# 3. 其他配置可以使用默认值
# 4. 生产环境请修改安全相关配置（SECRET_KEY、ADMIN_PASSWORD等）
# 5. 敏感信息不要提交到版本控制系统
